{
  "$schema": "https://raw.githubusercontent.com/nicehash/tauri/refs/heads/dev/crates/tauri-config-schema/schema.json",
  "productName": "LvAIgent",
  "version": "1.0.2",
  "identifier": "com.mimo.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "LvAIgent",
        "width": 1600,
        "height": 900,
        "minWidth": 700,
        "minHeight": 500,
        "decorations": false,
        "devtools": false,
        "browserExtensionsEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://api.github.com; img-src 'self' asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'; object-src 'none'; base-uri 'none'; frame-src 'none'; form-action 'none'",
      "devCsp": null,
      "freezePrototype": true,
      "dangerousDisableAssetCspModification": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../mimo.exe": "mimo.exe",
      "../vendor/mimo-code/LICENSE": "licenses/MiMo-Code-LICENSE.txt",
      "../vendor/mimo-code/USE_RESTRICTIONS.md": "licenses/MiMo-Code-USE-RESTRICTIONS.md",
      "../THIRD_PARTY_NOTICES.md": "licenses/THIRD_PARTY_NOTICES.md"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller",
        "silent": true
      },
      "wix": null,
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installerHooks": "windows/installer-hooks.nsh",
        "installMode": "perMachine",
        "languages": ["Vietnamese", "English"],
        "displayLanguageSelector": false
      }
    }
  }
}
